{
  "name": "verceldrop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:start": "pnpm exec supabase start",
    "db:stop": "pnpm exec supabase stop",
    "db:restart": "pnpm exec supabase stop && pnpm exec supabase start",
    "db:status": "pnpm exec supabase status",
    "db:migrate": "pnpm exec supabase migration up",
    "db:reset": "pnpm exec supabase db reset",
    "db:diff": "pnpm exec supabase db diff",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push && tsx scripts/db-apply-sql.ts",
    "db:studio": "drizzle-kit studio",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/stripe/webhook",
    "dev:all": "pnpm db:restart && concurrently -n next,stripe -c blue,magenta \"pnpm dev\" \"pnpm stripe:listen\""
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "supabase"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@neondatabase/serverless": "^1.1.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.1",
    "@vercel/blob": "^2.3.3",
    "@vercel/oidc": "^3.2.1",
    "ai": "^6.0.170",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.11.0",
    "next": "16",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "posthog-js": "^1.372.3",
    "posthog-node": "^5.30.6",
    "react": "19",
    "react-dom": "19",
    "server-only": "^0.0.1",
    "shadcn": "^4.5.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "workflow": "^4.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.5",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.0.2",
    "supabase": "^2.95.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
